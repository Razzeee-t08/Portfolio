@page "/home"
@page "/"
@inject NavigationManager Navigation

<PageTitle>Home</PageTitle>

<section class="hero">
    <div class="hero__content">

        <img src="profile.jpg" alt="Profile" class="hero__image" />

        <span class="hero__badge">BSIT-2A Student</span>

        <h1 class="hero__title">@Name</h1>

        <p class="hero__description">@Bio</p>

        <div class="hero__actions">
            <a href="/about" class="btn btn--primary">About Me</a>
            <a href="/contact" class="btn btn--secondary">Contact Me</a>
        </div>

    </div>
</section>

@code {
    string Name = "Jezzar Lexus L. Taneo";
    string Bio = "A disciplined BSIT student passionate about software development and continuous improvement.";

}